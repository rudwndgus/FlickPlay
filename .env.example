# 브라우저에 공개되어도 되는 Supabase 값만 이 파일의 형식으로 사용합니다.
# 실제 값은 커밋하지 말고, 집 컴퓨터의 .env.local에만 입력하세요.
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=YOUR_PUBLISHABLE_KEY

# 절대 VITE_ 접두사로 만들거나 GitHub에 올리면 안 되는 값:
# SUPABASE_SECRET_KEY, SUPABASE_SERVICE_ROLE_KEY, DATABASE_PASSWORD, ACCESS_TOKEN
